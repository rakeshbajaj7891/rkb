{
 "cells": [
  {
   "cell_type": "markdown",
   "source": [
    "# 📚 Hybrid RAG System (CrewAI + Groq)\n",
    "\n",
    "This notebook demonstrates a Hybrid Retrieval-Augmented Generation system using:\n",
    "- Dense Embeddings (FAISS)\n",
    "- Sparse Retrieval (BM25)\n",
    "- CrewAI Agents\n",
    "- Groq + Llama 3.1 8B Instant\n",
    "- Gradio UI"
   ],
   "metadata": {}
  },
  {
   "cell_type": "code",
   "source": [
    "!pip install crewai langchain langchain-community langchain-groq pypdf faiss-cpu sentence-transformers rank_bm25 gradio"
   ],
   "metadata": {}
  },
  {
   "cell_type": "code",
   "source": [
    "import os\n",
    "import gradio as gr\n",
    "\n",
    "from langchain_groq import ChatGroq\n",
    "from langchain.document_loaders import PyPDFLoader\n",
    "from langchain.text_splitter import RecursiveCharacterTextSplitter\n",
    "\n",
    "from sentence_transformers import SentenceTransformer\n",
    "import faiss\n",
    "\n",
    "from rank_bm25 import BM25Okapi\n",
    "\n",
    "from crewai import Agent, Task, Crew"
   ],
   "metadata": {}
  },
  {
   "cell_type": "code",
   "source": [
    "# Set your Groq API key\n",
    "os.environ[\"GROQ_API_KEY\"] = \"YOUR_GROQ_API_KEY\""
   ],
   "metadata": {}
  },
  {
   "cell_type": "code",
   "source": [
    "# Initialize LLM\n",
    "llm = ChatGroq(\n",
    "    model=\"llama-3.1-8b-instant\",\n",
    "    temperature=0.3\n",
    ")"
   ],
   "metadata": {}
  },
  {
   "cell_type": "code",
   "source": [
    "# CrewAI Agent\n",
    "rag_agent = Agent(\n",
    "    role=\"Hybrid RAG AI Specialist\",\n",
    "    goal=\"Retrieve and summarize relevant information using hybrid search\",\n",
    "    backstory=\"Expert in combining dense and sparse retrieval for accuracy\",\n",
    "    llm=llm,\n",
    "    verbose=True\n",
    ")"
   ],
   "metadata": {}
  },
  {
   "cell_type": "code",
   "source": [
    "def load_pdf(file):\n",
    "    loader = PyPDFLoader(file.name)\n",
    "    return loader.load()"
   ],
   "metadata": {}
  },
  {
   "cell_type": "code",
   "source": [
    "def chunk_documents(docs):\n",
    "    splitter = RecursiveCharacterTextSplitter(chunk_size=500, chunk_overlap=50)\n",
    "    chunks = splitter.split_documents(docs)\n",
    "    return chunks, [c.page_content for c in chunks]"
   ],
   "metadata": {}
  },
  {
   "cell_type": "code",
   "source": [
    "def dense_retrieval(chunks, query, top_k=3):\n",
    "    model = SentenceTransformer(\"all-MiniLM-L6-v2\")\n",
    "    texts = [c.page_content for c in chunks]\n",
    "    embeddings = model.encode(texts)\n",
    "\n",
    "    index = faiss.IndexFlatL2(len(embeddings[0]))\n",
    "    index.add(embeddings)\n",
    "\n",
    "    query_vec = model.encode([query])\n",
    "    scores, indices = index.search(query_vec, top_k)\n",
    "\n",
    "    return [texts[i] for i in indices[0]]"
   ],
   "metadata": {}
  },
  {
   "cell_type": "code",
   "source": [
    "def sparse_retrieval(chunks, query, top_k=3):\n",
    "    texts = [c.page_content for c in chunks]\n",
    "    tokenized = [t.split() for t in texts]\n",
    "\n",
    "    bm25 = BM25Okapi(tokenized)\n",
    "    scores = bm25.get_scores(query.split())\n",
    "\n",
    "    top_idx = sorted(range(len(scores)), key=lambda i: scores[i], reverse=True)[:top_k]\n",
    "    return [texts[i] for i in top_idx]"
   ],
   "metadata": {}
  },
  {
   "cell_type": "code",
   "source": [
    "def hybrid_retrieval(chunks, query):\n",
    "    dense = dense_retrieval(chunks, query)\n",
    "    sparse = sparse_retrieval(chunks, query)\n",
    "    return list(set(dense + sparse))"
   ],
   "metadata": {}
  },
  {
   "cell_type": "code",
   "source": [
    "def generate_summary(context):\n",
    "    task = Task(\n",
    "        description=f\"\"\"\n",
    "        Summarize the following context:\n",
    "        {context}\n",
    "        Provide key insights and structured summary.\n",
    "        \"\"\",\n",
    "        agent=rag_agent\n",
    "    )\n",
    "\n",
    "    crew = Crew(agents=[rag_agent], tasks=[task], verbose=True)\n",
    "    return crew.kickoff()"
   ],
   "metadata": {}
  },
  {
   "cell_type": "code",
   "source": [
    "def process_pdf(file, query):\n",
    "    docs = load_pdf(file)\n",
    "\n",
    "    chunks, chunk_texts = chunk_documents(docs)\n",
    "    retrieved = hybrid_retrieval(chunks, query)\n",
    "    summary = generate_summary(\"\\n\\n\".join(retrieved))\n",
    "\n",
    "    return (\n",
    "        \"\\n---\\n\".join(chunk_texts[:5]),\n",
    "        \"\\n---\\n\".join(retrieved),\n",
    "        summary\n",
    "    )"
   ],
   "metadata": {}
  },
  {
   "cell_type": "code",
   "source": [
    "def launch_ui():\n",
    "    with gr.Blocks(theme=gr.themes.Soft()) as demo:\n",
    "\n",
    "        gr.HTML(\"\"\"\n",
    "        <div style='text-align:center;'>\n",
    "        <h1>📚 Hybrid RAG System</h1>\n",
    "        <marquee>Upload PDF | Hybrid Search | AI Summary</marquee>\n",
    "        </div>\n",
    "        \"\"\")\n",
    "\n",
    "        file_input = gr.File(label=\"Upload PDF\")\n",
    "        query_input = gr.Textbox(label=\"Ask a question\")\n",
    "\n",
    "        chunk_out = gr.Textbox(label=\"Chunks\", lines=10)\n",
    "        retrieval_out = gr.Textbox(label=\"Retrieved Context\", lines=10)\n",
    "        summary_out = gr.Textbox(label=\"Summary\", lines=10)\n",
    "\n",
    "        btn = gr.Button(\"Run\")\n",
    "\n",
    "        btn.click(fn=process_pdf, inputs=[file_input, query_input], outputs=[chunk_out, retrieval_out, summary_out])\n",
    "\n",
    "    return demo\n",
    "\n",
    "app = launch_ui()\n",
    "app.launch()"
   ],
   "metadata": {}
  }
 ],
